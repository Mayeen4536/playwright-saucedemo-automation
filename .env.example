# Copy this file to .env and adjust values for your machine.
# .env is git-ignored — never commit real values.

# Selects which environment config/environments.ts should use: qa | staging
TEST_ENV=qa

# Optional per-environment overrides. If unset, each environment falls back
# to the public SauceDemo URL (see config/environments.ts).
QA_BASE_URL=https://www.saucedemo.com/
STAGING_BASE_URL=https://www.saucedemo.com/
